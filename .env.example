# Gemini API Configuration
# Get your API key from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configuration (Dashboard → Project Settings → API)
# 本番の URL / キーをリポジトリにコミットしないこと
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# For frameworks expecting NEXT_PUBLIC_* env vars (e.g. Vercel hosting)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# AI Feature Toggle (set to 1 to disable AI features)
# VITE_AI_OFF=0
# VITE_IS_AI_DISABLED=false
